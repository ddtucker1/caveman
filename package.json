{
  "name": "wildborn",
  "version": "1.0.0",
  "description": "Wildborn — procedurally evolving 2D survival (standalone desktop)",
  "author": "Wildborn",
  "desktopName": "Wildborn.desktop",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "play": "electron .",
    "test": "node test/ecosystem-smoke.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:win": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.wildborn.game",
    "productName": "Wildborn",
    "artifactName": "${productName}-${version}-${os}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "src/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Game",
      "executableName": "Wildborn",
      "syncDesktopName": true
    },
    "win": {
      "target": ["portable"],
      "executableName": "Wildborn"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.games"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
